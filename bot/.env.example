# ============================================================
#  Video Autopublish Bot — MVP (@Saramudpost_bot)
#  Все секреты прокидываются в ПРОЦЕСС n8n (Docker env_file /
#  systemd Environment=), а НЕ в UI Variables. Тогда $env работает
#  в выражениях. YouTube — исключение: OAuth2 через n8n credential.
# ============================================================

# --- TELEGRAM (Bot API, прямой) ---
TELEGRAM_BOT_TOKEN=token_from_botfather
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxxxxxxxx

# --- ANTHROPIC / CLAUDE ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- VK (официальный API, прямой) ---
VK_ACCESS_TOKEN=token_with_video_wall_scopes
VK_OWNER_ID=-123456789          # отрицательный = сообщество

# --- LINKEDIN (UGC API, токен ~60 дней) ---
LINKEDIN_ACCESS_TOKEN=AQX...
LINKEDIN_AUTHOR_URN=urn:li:person:xxxxxxxx   # или urn:li:organization:xxxx

# --- REDDIT (script app, password grant) ---
REDDIT_USERNAME=your_reddit_login
REDDIT_PASSWORD=your_reddit_password
REDDIT_SUBREDDIT=your_subreddit_without_r_slash
# client_id и secret кладутся в n8n credential "Reddit App" (Basic Auth),
# т.к. идут в заголовок Authorization при получении токена.

# --- GITHUB (коммит статьи на сайт saramudvlad.ru) ---
GITHUB_TOKEN=ghp_xxx              # PAT со scope: contents:write на репо
GITHUB_REPO=vladsaram/vladsaram.github.io
GITHUB_BRANCH=main

# --- YOUTUBE ---
# НЕ в env. OAuth2 (токен живёт 1 час, авто-рефреш) → только через
# n8n Credentials → "YouTube OAuth2 API". См. SETUP.md, раздел YouTube.

# ============================================================
#  Фаза 2 (после аудита/ревью приложений) — пока выключено:
#  Instagram (Graph API), TikTok (Content Posting API)
#  Likee — нет публичного API, в проект не входит.
# ============================================================
