# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxxxxxxxx

# === ANTHROPIC / CLAUDE ===
ANTHROPIC_API_KEY=sk-ant-api03-...

# === VK ===
VK_ACCESS_TOKEN=your_vk_user_or_community_token
VK_OWNER_ID=-123456789   # negative = group/community

# === YOUTUBE ===
# OAuth2 credentials set up in n8n → Credentials → YouTube OAuth2 API
# YOUTUBE_CHANNEL_ID not needed — handled via OAuth2

# === INSTAGRAM (Graph API) ===
INSTAGRAM_USER_ID=17841400000000000
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxx

# === TIKTOK (Content Posting API) ===
TIKTOK_ACCESS_TOKEN=your_tiktok_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# === LIKEE (via Ayrshare) ===
AYRSHARE_API_KEY=your_ayrshare_api_key   # optional, ~$29/mo
